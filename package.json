{
    "name": "contributions-generator",
    "version": "1.0.0",
    "description": "Web Application allowing to generate Github activity",
    "keywords": [
        "github activity",
        "github contributions"
    ],
    "author": "loktionov129",
    "license": "MIT",
    "scripts": {
        "gulp": "gulp",
        "eslint": "eslint",
        "htmllint": "htmllint",
        "stylelint": "stylelint --fix --config ./.stylelintrc",
        "lint:js": "npm run eslint -- --fix --config ./.eslintrc.json",
        "lint:html": "htmllint --fix --config ./.htmllintrc ./src/**/*.html",
        "lint:less": "stylelint",
        "clean": "npm run gulp -- -f gulp/main.js cleanTask",
        "build": "npm run gulp -- -f gulp/main.js buildTask --production",
        "start": "npm run gulp -- -f gulp/main.js"
    },
    "bin": {
        "contributions-generator": "bin/cli.js"
    },
    "main": "bin/cli.js",
    "engines": {
        "node": ">=6.0.1"
    },
    "lint-staged": {
        "*.js": [
            "npm run lint:js",
            "git add"
        ],
        "*.html": [
            "npm run lint:html",
            "git add"
        ],
        "*.less": [
            "npm run lint:less",
            "git add"
        ]
    },
    "husky": {
        "hooks": {
            "pre-commit": "lint-staged"
        }
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "devDependencies": {
        "browser-sync": "3.0.4",
        "eslint": "10.2.0",
        "htmllint": "0.8.0",
        "htmllint-cli": "0.0.7",
        "husky": "9.1.7",
        "lint-staged": "16.4.0",
        "stylelint": "17.6.0"
    },
    "dependencies": {
        "@babel/core": "7.29.0",
        "@babel/preset-env": "7.29.2",
        "babelify": "10.0.0",
        "browserify": "17.0.1",
        "del": "8.0.1",
        "gulp": "5.0.1",
        "gulp-autoprefixer": "10.0.0",
        "gulp-clean-css": "4.3.0",
        "gulp-concat": "2.6.1",
        "gulp-group-css-media-queries": "1.2.2",
        "gulp-htmlmin": "5.0.1",
        "gulp-less": "5.0.0",
        "gulp-noop": "1.0.1",
        "gulp-plumber": "1.2.1",
        "gulp-sourcemaps": "3.0.0",
        "gulp-size": "5.0.0",
        "gulp-token-replace": "1.1.5",
        "gulp-uglify": "3.0.2",
        "vinyl-buffer": "1.0.1",
        "vinyl-source-stream": "2.0.0",
        "watchify": "4.0.0"
    }
}
